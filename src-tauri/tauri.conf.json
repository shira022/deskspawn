{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "DeskSpawn",
  "version": "0.2.0",
  "identifier": "com.deskspawn.app",
  "build": {
    "beforeDevCommand": "node scripts/build-sidecar.mjs --dev && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:sidecar && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeskSpawn",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/deskspawn-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3MjQ1Mjc4NjQ5OTUwNApSV1FFbFVtR0owVnlBc1JUa1ZNVmdMU0lWa250WkZUNTAxdlJkdHUyOFRNYnBpMGVQME1RZTFzRgo=",
      "endpoints": [
        "https://shira022.github.io/deskspawn/updates.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
